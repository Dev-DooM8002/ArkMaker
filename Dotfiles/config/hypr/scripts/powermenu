#!/bin/bash

options="ï€‘  Apagar
ï€¡  Reiniciar
ï††  Suspender
ï€£  Bloquear
ï‚‹  Cerrar sesiÃ³n
ó°œº  Cancelar"

choice=$(printf "%s" "$options" | fuzzel \
                                        --dmenu \
                                        --lines=6 \
                                        --width=17 \
                                        --inner-pad=5 \
                                        --placeholder="" \
                                        --anchor=top-right \
                                        --x-margin=20 \
                                        --y-margin=20 
)

case "$choice" in
    "ï€‘  Apagar") systemctl poweroff ;;
    "ï€¡  Reiniciar") systemctl reboot ;;
    "ï††  Suspender") systemctl suspend ;;
    "ï€£  Bloquear") hyprlock ;;
    "ï‚‹  Cerrar sesiÃ³n") hyprctl dispatch exit ;;
    *) exit 0 ;;
esac




